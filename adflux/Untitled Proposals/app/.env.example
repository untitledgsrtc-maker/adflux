# Untitled Proposals — environment template
# Copy to .env.local and fill in.

# --- Supabase (browser-safe; RLS protects everything) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...your-anon-key

# --- Brand identity (shown in the PDF header / topbar) ---
VITE_BRAND_NAME=Untitled Advertising
VITE_BRAND_NAME_GU=અનટાઈટલ્ડ એડવર્ટાઈઝિંગ
VITE_BRAND_GSTIN=24AAAAA0000A1Z5
VITE_BRAND_PAN=AAAAA0000A
VITE_BRAND_HSN=998361

# --- PDF render API (the Vercel serverless function) ---
# In dev this can point at the same origin if you run vercel dev,
# or a separate localhost:3001 if you run the api/ folder standalone.
VITE_PDF_API_URL=/api/render-pdf

# --- App-level toggles ---
VITE_PROPOSAL_DEFAULT_EXPIRE_DAYS=120
