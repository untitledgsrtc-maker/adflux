{
  "name": "untitled-proposals",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Bilingual proposal generator + payment tracker for Untitled Advertising",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 4173",
