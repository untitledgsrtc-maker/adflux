# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...    # SECRET — Vercel only

# Brand block (printed on every PDF)
BRAND_NAME=Untitled Advertising
BRAND_NAME_GU=અનટાઈટલ્ડ એડવર્ટાઇઝિંગ
BRAND_GSTIN=24XXXXX0000X1ZX
BRAND_PAN=XXXXX0000X
BRAND_HSN=998361

# CORS — comma-separated origins; defaults to "*"
ALLOWED_ORIGINS=https://untitled-proposals.vercel.app

# Cron protection — set to a long random string. Vercel sends it as
# `Authorization: Bearer ${CRON_SECRET}` on scheduled invocations.
CRON_SECRET=replace-with-long-random-string

# Local dev only (uses regular puppeteer instead of @sparticuz/chromium)
# RUN_LOCAL=1
